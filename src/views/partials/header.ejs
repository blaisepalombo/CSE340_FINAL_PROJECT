<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
  <header class="site-header">
    <div class="container">
      <nav class="site-nav">
        <a class="logo" href="/">Vintage Car Hub</a>

        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/cars">Cars</a>

          <% if (loggedIn) { %>
            <a href="/account">Account</a>
            <a href="/projects">My Projects</a>
            <% if (user && (user.role_name === "admin" || user.role_name === "moderator")) { %>
              <a href="/projects/manage">Manage Projects</a>
              <a href="/comments/manage">Manage Comments</a>
            <% } %>
            <% if (user && user.role_name === "admin") { %>
              <a href="/cars/manage">Manage Cars</a>
              <a href="/categories/manage">Manage Categories</a>
            <% } %>
            <a href="/logout">Logout</a>
          <% } else { %>
            <a href="/login">Login</a>
            <a href="/register">Register</a>
          <% } %>
        </div>
      </nav>
    </div>
  </header>

  <main class="container">