<%- include("../partials/header", { title: title }) %>

<section class="page-section form-section wide-form-section">
  <div class="section-header stacked-mobile">
    <div>
      <h1>Edit Restoration Project</h1>
      <p><strong>Linked Car:</strong> <%= project.year %> <%= project.make %> <%= project.model %></p>
      <p><strong>Current Status:</strong> <span class="project-status project-status-<%= project.current_status.replace(/\s+/g, '-') %>"><%= project.current_status %></span></p>
    </div>

    <form action="/projects/<%= project.project_id %>/delete" method="post" onsubmit="return confirm('Delete this project?');">
      <button type="submit" class="button button-danger">Delete Project</button>
    </form>
  </div>

  <% if (errors.length > 0) { %>
    <div class="message error-message">
      <ul>
        <% errors.forEach(error => { %>
          <li><%= error %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <form action="/projects/<%= project.project_id %>/update" method="post" class="auth-form">
    <label for="title">Project Title</label>
    <input type="text" id="title" name="title" value="<%= formData.title || '' %>" required>

    <label for="description">Project Description</label>
    <textarea id="description" name="description" rows="6" required><%= formData.description || '' %></textarea>

    <label for="started_on">Started On</label>
    <input type="date" id="started_on" name="started_on" value="<%= formData.started_on || '' %>">

    <label for="target_completion">Target Completion</label>
    <input type="date" id="target_completion" name="target_completion" value="<%= formData.target_completion || '' %>">

    <button type="submit" class="button">Save Changes</button>
  </form>
</section>

<section class="page-section">
  <h2>Status History</h2>

  <% if (history.length === 0) { %>
    <p>No status history yet.</p>
  <% } else { %>
    <div class="history-list">
      <% history.forEach(item => { %>
        <article class="history-item">
          <p><strong>Status:</strong> <%= item.status %></p>
          <p><strong>Updated:</strong> <%= new Date(item.created_at).toLocaleString() %></p>
          <p><strong>By:</strong> <%= item.first_name ? `${item.first_name} ${item.last_name}` : "System" %></p>
          <p><strong>Notes:</strong> <%= item.notes || "No notes added." %></p>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include("../partials/footer") %>