<%- include("../partials/header", { title: title }) %>

<section class="page-section">
  <h1><%= car.year %> <%= car.make %> <%= car.model %></h1>

  <p><strong>Category:</strong> <%= car.category_name %></p>
  <p><strong>Price:</strong> $<%= Number(car.price).toLocaleString() %></p>
  <p><strong>Description:</strong> <%= car.description %></p>
  <% if (loggedIn) { %>
    <a class="button" href="/projects/new?carId=<%= car.car_id %>">Start Restoration Project</a>
  <% } else { %>
    <p><a class="text-link" href="/login">Log in</a> to start a restoration project for this car.</p>
  <% } %>
</section>

<section class="page-section">
  <h2>Images</h2>

  <% if (images.length === 0) { %>
    <p>No images available.</p>
  <% } else { %>
    <div class="car-images">
      <% images.forEach(image => { %>
        <img
          src="<%= image.image_url %>"
          alt="<%= image.alt_text %>"
          class="car-image"
        >
      <% }) %>
    </div>
  <% } %>
</section>

<%- include("../partials/footer") %>