<%- include("../partials/header", { title: title }) %>

<section class="page-section">
  <h1><%= car.year %> <%= car.make %> <%= car.model %></h1>

  <p><strong>Category:</strong> <%= car.category_name %></p>
  <p><strong>Price:</strong> $<%= Number(car.price).toLocaleString() %></p>
  <p><strong>Description:</strong> <%= car.description %></p>

  <% if (loggedIn) { %>
    <a class="button" href="/projects/new?carId=<%= car.car_id %>">Start Restoration Project</a>
  <% } else { %>
    <p><a class="text-link" href="/login">Log in</a> to start a restoration project for this car.</p>
  <% } %>
</section>

<section class="page-section">
  <h2>Images</h2>

  <% if (images.length === 0) { %>
    <p>No images available.</p>
  <% } else { %>
    <div class="car-images">
      <% images.forEach(image => { %>
        <img
          src="<%= image.image_url %>"
          alt="<%= image.alt_text %>"
          class="car-image"
        >
      <% }) %>
    </div>
  <% } %>
</section>

<section class="page-section" id="comments">
  <div class="section-header">
    <div>
      <h2>Comments</h2>
      <p>Users can leave comments tied to their account and manage their own submissions.</p>
    </div>
  </div>

  <% if (errors && errors.length > 0) { %>
    <div class="message error-message">
      <ul>
        <% errors.forEach(error => { %>
          <li><%= error %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <% if (loggedIn) { %>
    <form action="/cars/<%= car.car_id %>/comments" method="post" class="auth-form compact-form">
      <label for="comment_text">Add a Comment</label>
      <textarea
        id="comment_text"
        name="comment_text"
        rows="4"
        maxlength="1000"
        required
      ><%= commentFormData?.comment_text || "" %></textarea>
      <button type="submit" class="button">Post Comment</button>
    </form>
  <% } else { %>
    <p><a class="text-link" href="/login">Log in</a> to post a comment.</p>
  <% } %>

  <div class="comments-list">
    <% if (!comments || comments.length === 0) { %>
      <p>No comments yet.</p>
    <% } else { %>
      <% comments.forEach(comment => { %>
        <article class="comment-card">
          <div class="comment-meta">
            <p>
              <strong><%= comment.first_name %> <%= comment.last_name %></strong>
            </p>
            <p>
              Posted <%= new Date(comment.created_at).toLocaleString() %>
              <% if (comment.updated_at && String(comment.updated_at) !== String(comment.created_at)) { %>
                • Edited <%= new Date(comment.updated_at).toLocaleString() %>
              <% } %>
            </p>
          </div>

          <% if (loggedIn && user && user.user_id === comment.user_id && editingCommentId === comment.comment_id) { %>
            <form action="/comments/<%= comment.comment_id %>/update" method="post" class="auth-form compact-form">
              <label for="edit_comment_<%= comment.comment_id %>">Edit Comment</label>
              <textarea
                id="edit_comment_<%= comment.comment_id %>"
                name="comment_text"
                rows="4"
                maxlength="1000"
                required
              ><%= commentFormData?.comment_text || comment.comment_text %></textarea>
              <div class="inline-actions">
                <button type="submit" class="button">Save Comment</button>
                <a href="/cars/<%= car.car_id %>#comments" class="button button-secondary">Cancel</a>
              </div>
            </form>
          <% } else { %>
            <p class="comment-text"><%= comment.comment_text %></p>

            <% if (loggedIn && user && user.user_id === comment.user_id) { %>
              <details class="comment-edit-toggle">
                <summary class="text-link">Edit comment</summary>
                <form action="/comments/<%= comment.comment_id %>/update" method="post" class="auth-form compact-form">
                  <label for="quick_edit_comment_<%= comment.comment_id %>">Update Comment</label>
                  <textarea
                    id="quick_edit_comment_<%= comment.comment_id %>"
                    name="comment_text"
                    rows="4"
                    maxlength="1000"
                    required
                  ><%= comment.comment_text %></textarea>
                  <div class="inline-actions">
                    <button type="submit" class="button">Save Comment</button>
                  </div>
                </form>
              </details>

              <form
                action="/comments/<%= comment.comment_id %>/delete"
                method="post"
                class="inline-form"
                onsubmit="return confirm('Delete this comment?');"
              >
                <button type="submit" class="button button-danger">Delete</button>
              </form>
            <% } %>

            <% if (loggedIn && user && (user.role_name === "admin" || user.role_name === "moderator")) { %>
              <form
                action="/comments/<%= comment.comment_id %>/moderate-delete"
                method="post"
                class="inline-form"
                onsubmit="return confirm('Remove this comment as staff?');"
              >
                <button type="submit" class="button button-danger">Moderate Delete</button>
              </form>
            <% } %>
          <% } %>
        </article>
      <% }) %>
    <% } %>
  </div>
</section>

<%- include("../partials/footer") %>