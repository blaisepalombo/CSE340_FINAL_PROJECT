<%- include("../partials/header", { title: title }) %>

<section class="page-section">
  <div class="section-header">
    <div>
      <h1>Manage Cars</h1>
      <p>Admins can add, edit, and remove cars from the showcase inventory.</p>
    </div>
    <a class="button" href="/cars/new">Add Car</a>
  </div>

  <% if (!cars || cars.length === 0) { %>
    <p>No cars found.</p>
  <% } else { %>
    <div class="project-grid">
      <% cars.forEach(car => { %>
        <article class="project-card">
          <h2><%= car.year %> <%= car.make %> <%= car.model %></h2>
          <p><strong>Category:</strong> <%= car.category_name || "Uncategorized" %></p>
          <p><strong>Price:</strong> $<%= Number(car.price).toLocaleString() %></p>
          <p><strong>Status:</strong> <%= car.availability_status %></p>
          <p><strong>Featured:</strong> <%= car.featured ? "Yes" : "No" %></p>
          <p><%= car.description %></p>

          <div class="inline-actions">
            <a class="button" href="/cars/<%= car.car_id %>">View</a>
            <a class="button button-secondary" href="/cars/<%= car.car_id %>/edit">Edit</a>
            <form
              action="/cars/<%= car.car_id %>/delete"
              method="post"
              class="inline-form"
              onsubmit="return confirm('Delete this car and its related records?');"
            >
              <button type="submit" class="button button-danger">Delete</button>
            </form>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<%- include("../partials/footer") %>